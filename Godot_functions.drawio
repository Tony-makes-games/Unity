<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.5.2 Chrome/142.0.7444.265 Electron/39.6.1 Safari/537.36" version="29.5.2">
  <diagram name="Page-1" id="H585ezmtPK3t3z4TuKZe">
    <mxGraphModel dx="284" dy="611" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="Tio8lfPetjoWl_DhGvMQ-1" parent="1" style="whiteSpace=wrap;html=1;" value="&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;Physics_process - handles all physics based logics,&lt;/span&gt;&lt;div&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;runs at fixed rate(typically 60 per second) with consistent delta&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;Used to move kinematic body or rigid body with move_and_slide()&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;apply forces and impulses, physics queries like raycasting&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: light-dark(#ffffff, var(--ge-dark-color, #121212));&quot;&gt;check input with _process and _input and handle logic of input in physics process for better results on different machines of varying frame rate.&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="120" width="510" x="30" y="70" as="geometry" />
        </mxCell>
        <mxCell id="Tio8lfPetjoWl_DhGvMQ-2" parent="1" style="whiteSpace=wrap;html=1;" value="process - handles all visual updates and non physics based input handling&lt;div&gt;ideal for handling inputs every frame, providing immediate feedback&lt;/div&gt;&lt;div&gt;is called once per rendered frame, making to tied to game&#39;s frame rate&lt;/div&gt;&lt;div&gt;benefit being as smooth as monitor refresh rate allows&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="510" x="30" y="220" as="geometry" />
        </mxCell>
        <mxCell id="Tio8lfPetjoWl_DhGvMQ-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Functions" vertex="1">
          <mxGeometry height="30" width="60" x="210" y="20" as="geometry" />
        </mxCell>
        <mxCell id="Tio8lfPetjoWl_DhGvMQ-6" parent="1" style="whiteSpace=wrap;html=1;" value="_input - used for raw input events,&amp;nbsp; like mouse clicks or touch inputs and only gets triggered when input occurs" vertex="1">
          <mxGeometry height="60" width="510" x="30" y="310" as="geometry" />
        </mxCell>
